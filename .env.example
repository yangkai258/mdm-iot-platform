# ============================================
# MDM IoT Platform 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ========== 后端配置 ==========
PORT=8080
GIN_MODE=release

# JWT 认证（生产环境必须修改）
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=mdm_user
DB_PASSWORD=mdm_password
DB_NAME=mdm_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT / EMQX
EMQX_DASHBOARD__DEFAULT_PASSWORD=admin
EMQX__LISTENERS__TCP__DEFAULT=1883
EMQX__LISTENERS__WS__DEFAULT=8083
EMQX__LISTENERS__WSS__DEFAULT=8084

# CORS（用逗号分隔，允许的域名）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 日志级别（debug/info/warn/error）
LOG_LEVEL=info

# ========== 前端配置 ==========
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_TITLE=MDM IoT Platform
VITE_USE_MOCK=false
